{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ADT Event Schema",
  "description": "Authoritative Data Source event format per ADT Framework (Sheridan, 2026)",
  "type": "object",
  "required": ["id", "ts", "agent", "role", "action_type", "spec_ref", "authority", "authorized"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique event identifier (format: evt_YYYYMMDD_HHMMSS_XXX)",
      "pattern": "^evt_[0-9]{8}_[0-9]{6}_[0-9]{3}$"
    },
    "ref_id": {
      "type": ["string", "null"],
      "description": "Optional reference to a previous event ID being addressed or resolved",
      "pattern": "^evt_[0-9]{8}_[0-9]{6}_[0-9]{3}$"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of event"
    },
    "session_id": {
      "type": "string",
      "description": "Groups events by work session"
    },
    "agent": {
      "type": "string",
      "enum": ["CLAUDE", "GEMINI"],
      "description": "Which AI system performed the action"
    },
    "role": {
      "type": "string",
      "enum": [
        "Systems_Architect",
        "Product_Manager",
        "Mechanical_Engineer",
        "Electrical_Engineer",
        "Embedded_Engineer",
        "Network_Engineer",
        "Backend_Engineer",
        "Frontend_Engineer",
        "DevOps_Engineer",
        "QA_Engineer",
        "Integration_Engineer",
        "Overseer"
      ],
      "description": "Role the agent was operating as"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "session_start",
        "session_end",
        "task_lock",
        "task_unlock",
        "file_read",
        "file_edit",
        "file_create",
        "file_delete",
        "request_sent",
        "request_received",
        "spec_created",
        "spec_approved",
        "escalation",
        "escalation_resolution",
        "physical_action",
        "unauthorized_attempt",
        "jurisdiction_violation",
        "lock_conflict",
        "adt_sync"
      ],
      "description": "Type of action performed"
    },
    "spec_ref": {
      "type": ["string", "null"],
      "description": "Reference to authorizing specification (e.g., SPEC-001). Null only for session_start/end and violations."
    },
    "authority": {
      "type": "string",
      "description": "What grants permission for this action (spec section, role jurisdiction, or 'NONE' for violations)"
    },
    "authorized": {
      "type": "boolean",
      "description": "Whether this action was authorized per ADT governance"
    },
    "rationale": {
      "type": "string",
      "description": "Decision context at point of execution"
    },
    "action_data": {
      "type": "object",
      "description": "Action-specific data",
      "properties": {
        "file": { "type": "string" },
        "lines_added": { "type": "integer" },
        "lines_removed": { "type": "integer" },
        "task": { "type": "string" },
        "target_role": { "type": "string" },
        "message": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "outcome": {
      "type": "string",
      "enum": ["success", "failure", "blocked", "pending"],
      "description": "Result of the action"
    },
    "escalation": {
      "type": "boolean",
      "default": false,
      "description": "Whether this event requires human attention"
    }
  }
}
